# Copy this to .env for local development
# Never commit .env to version control

JWT_SECRET_KEY=your-secret-key-here
UPSTREAM_URL=http://localhost:8080
IAM_LOGIN_URL=https://iam.gingersociety.org/#k8s-dashboard/login

# DEBUG=true  -> no Secure cookie flag, verbose logs (local dev)
# DEBUG=false -> Secure cookie flag enabled             (default / production)
DEBUG=true

# Comma-separated path prefixes that bypass JWT auth entirely
# EXCLUDED_PATHS=/health,/metrics,/public/assets
EXCLUDED_PATHS=/health

PORT=3001
